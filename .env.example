# --- Stripe ---
#
# TEST MODE (recommended for development — no real charges):
# 1. In Stripe Dashboard, toggle "Test mode" ON (top right).
# 2. Developers → API keys → copy Secret key starting with sk_test_...
# 3. Webhooks → Add endpoint (or use Stripe CLI: stripe listen --forward-to localhost:4000/api/stripe/webhook)
#    Copy the signing secret whsec_... from the test webhook.
# 4. Use test cards in Checkout, e.g. 4242 4242 4242 4242, any future date, any CVC, any ZIP.
#
# "Invalid API key": paste the Secret key again from Test mode (Developers → API keys), or roll the key there.
#
# LIVE MODE (real money — production only):
# Toggle Test mode OFF, use sk_live_... and a live webhook secret.
#
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=mxn
STRIPE_PRICE_CENTS=9900

# Frontend URL (redirects after Stripe Checkout)
FRONTEND_URL=http://localhost:3000

# --- Supabase (PostgreSQL + Auth) — obligatorio para arrancar la API ---
# Project Settings → API: Project URL y anon public key.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Solo backend (nunca en el frontend): Service role para operaciones administrativas.
SUPABASE_SERVICE_ROLE_KEY=

# Puerto del servidor Express (opcional; por defecto 4000)
PORT=4000

# Código de invitación para registrar usuarios con rol admin (auth)
ADMIN_INVITE_CODE=
